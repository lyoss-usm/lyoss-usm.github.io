---
interface Props {
	title: string;
	class?: string;
}
const { title, class: className = '' } = Astro.props;
---

<section class={`mb-12 ${className}`}>
	<h2 class="mb-4 font-heading text-2xl font-bold text-primary md:text-3xl">
		{title}
	</h2>
	<div class="prose-lg prose max-w-none text-base-content/80">
		<slot />
	</div>
</section>
