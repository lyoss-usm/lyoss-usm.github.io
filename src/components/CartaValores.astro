---
import { Heart, Users, CodeXml, Lightbulb, Shield, Globe } from '@lucide/astro';

interface Item {
	icon?: string;
	titulo: string;
	descripcion: string;
	color?: string;
}

const { items = [] } = Astro.props as { items: Item[] };

const icons = { Heart, Users, CodeXml, Lightbulb, Shield, Globe } as const;

const colorStyles: Record<string, { border: string; bg: string; text: string }> = {
	error:   { border: 'border-error/20',   bg: 'bg-error/10',   text: 'text-error' },
	success: { border: 'border-success/20', bg: 'bg-success/10', text: 'text-success' },
	info:    { border: 'border-info/20',    bg: 'bg-info/10',    text: 'text-info' },
	warning: { border: 'border-warning/20', bg: 'bg-warning/10', text: 'text-warning' },
	secondary: { border: 'border-secondary/20', bg: 'bg-secondary/10', text: 'text-secondary' },
	accent:  { border: 'border-accent/20',  bg: 'bg-accent/10',  text: 'text-accent' },
};
---

<section id="valores" class="not-prose py-16 bg-base-200">
	<div class="container mx-auto px-4">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-16">
				<h2 class="font-heading text-4xl font-bold text-base-content lg:text-5xl">
					Nuestros Valores
				</h2>
				<p class="mt-3 max-w-2xl mx-auto text-base-content/60 leading-relaxed">
					Los principios que guían cada decisión y acción en nuestra comunidad.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center">
				{
					items.map((v) => {
						const Icon = (v.icon && icons[v.icon as keyof typeof icons]) || Heart;
						const c = colorStyles[v.color || 'info'];
						return (
							<div class={`card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 border ${c.border} group hover:scale-105`}>
								<div class="card-body p-6">
									<div class={`w-16 h-16 rounded-full ${c.bg} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
										<Icon class={`w-8 h-8 ${c.text}`} />
									</div>

									<h3 class="text-xl font-bold text-base-content mb-3 font-heading">
										{v.titulo}
									</h3>

									<p class="text-sm text-base-content/60 leading-relaxed">
										{v.descripcion}
									</p>
								</div>
							</div>
						);
					})
				}
			</div>
		</div>
	</div>
</section>
