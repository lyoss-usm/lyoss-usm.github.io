---
import { Heart, Users, Code2, Lightbulb, Shield, Globe } from '@lucide/astro';

interface Item {
	titulo: string;
	descripcion: string;
	icon?: 'Heart' | 'Users' | 'Code2' | 'Lightbulb' | 'Shield' | 'Globe';
}

const { items = [] } = Astro.props as { items: Item[] };

const icons = { Heart, Users, Code2, Lightbulb, Shield, Globe } as const;
---

<section id="valores" class="py-24">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="mb-12 text-center">
			<h2 class="font-heading text-4xl font-bold text-base-content lg:text-5xl">
				Nuestros Valores
			</h2>
			<p class="mx-auto mt-3 max-w-2xl text-base-content/60">
				Los principios que guían cada decisión y acción en nuestra comunidad.
			</p>
		</div>

		<div class="grid auto-rows-fr grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
			{
				items.map((v) => {
					const Icon = (v.icon && icons[v.icon]) || Heart;
					return (
						<div class="h-full rounded-xl border border-base-content/10 bg-base-100/40 p-6 backdrop-blur-sm transition hover:border-base-content/20">
							<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-base-content/10">
								<Icon size={18} class="text-base-content/70" />
							</div>

							<h3 class="font-heading text-base font-bold text-base-content">{v.titulo}</h3>
							<p class="mt-2 text-sm leading-relaxed text-base-content/70">{v.descripcion}</p>
						</div>
					);
				})
			}
		</div>
	</div>
</section>
