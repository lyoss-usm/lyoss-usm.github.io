---
import { Heart, Users, CodeXml, Lightbulb, Shield, Globe } from '@lucide/astro';

interface Item {
	icon?: string;
	titulo: string;
	descripcion: string;
	color?: string;
}

const { items = [] } = Astro.props as { items: Item[] };

const icons = { Heart, Users, CodeXml, Lightbulb, Shield, Globe } as const;

const colorStyles: Record<string, { border: string; bg: string; text: string }> = {
	error: { border: 'border-error/20', bg: 'bg-error/10', text: 'text-error' },
	success: { border: 'border-success/20', bg: 'bg-success/10', text: 'text-success' },
	info: { border: 'border-info/20', bg: 'bg-info/10', text: 'text-info' },
	warning: { border: 'border-warning/20', bg: 'bg-warning/10', text: 'text-warning' },
	secondary: { border: 'border-secondary/20', bg: 'bg-secondary/10', text: 'text-secondary' },
	accent: { border: 'border-accent/20', bg: 'bg-accent/10', text: 'text-accent' }
};
---

<section id="valores" class="not-prose bg-base-200 py-16">
	<div class="container mx-auto px-4">
		<div class="mx-auto max-w-7xl">
			<div class="mb-16 text-center">
				<h2 class="font-heading text-4xl font-bold text-base-content lg:text-5xl">
					Nuestros Valores
				</h2>
				<p class="mx-auto mt-3 max-w-2xl leading-relaxed text-base-content/60">
					Los principios que guían cada decisión y acción en nuestra comunidad.
				</p>
			</div>

			<div class="grid grid-cols-1 justify-items-center gap-8 md:grid-cols-2 lg:grid-cols-3">
				{
					items.map((v) => {
						const Icon = (v.icon && icons[v.icon as keyof typeof icons]) || Heart;
						const c = colorStyles[v.color || 'info'];
						return (
							<div
								class={`card border bg-base-100 shadow-lg transition-all duration-300 hover:shadow-xl ${c.border} group hover:scale-105`}
							>
								<div class="card-body p-6">
									<div
										class={`h-16 w-16 rounded-full ${c.bg} mb-4 flex items-center justify-center transition-transform duration-300 group-hover:scale-110`}
									>
										<Icon class={`h-8 w-8 ${c.text}`} />
									</div>

									<h3 class="mb-3 font-heading text-xl font-bold text-base-content">{v.titulo}</h3>

									<p class="text-sm leading-relaxed text-base-content/60">{v.descripcion}</p>
								</div>
							</div>
						);
					})
				}
			</div>
		</div>
	</div>
</section>
