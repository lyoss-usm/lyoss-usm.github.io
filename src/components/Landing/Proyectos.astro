---
import { getProyectos } from '@/utils/collect';
import CartaProyectoFull from '../CartaProyectoFull.astro';

const [proyectos, _] = getProyectos();
---

<section id="proyectos" class="bg-base-200">
	<div class="container mx-auto px-4 py-16">
		<div class="mb-12 flex items-center justify-between">
			<div>
				<h2 class="mb-2 font-heading text-4xl font-bold text-base-content">
					Proyectos de la Comunidad
				</h2>
				<p class="text-base-content/70">Lo que estamos construyendo actualmente.</p>
			</div>
			<a href="/proyectos" class="btn btn-outline max-sm:hidden" data-umami-event="ver-proyectos">
				Ver todos los proyectos
			</a>
			<a href="/proyectos" class="btn btn-outline sm:hidden" data-umami-event="ver-proyectos">
				Ver todos
			</a>
		</div>

		<div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
			{proyectos.slice(0, 6).map((p) => <CartaProyectoFull {...p} />)}
		</div>
	</div>
</section>
